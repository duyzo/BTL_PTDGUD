# Configuration Example

# URL của ứng dụng
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret key cho JWT (nếu chuyển sang NextAuth hoặc JWT custom sau này)
JWT_SECRET=your_jwt_secret_here_replace_in_production

# Cấu hình Mock Database (ví dụ URL kết nối MongoDB/PostgreSQL nếu có)
DATABASE_URL=mock_database_url_string

# Cấu hình thanh toán (Ví dụ: VietQR / Momo / ZaloPay Client ID)
VIETQR_CLIENT_ID=your_vietqr_client_id
